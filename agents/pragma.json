{
  "name": "pragma",
  "description": "Agent corporativo Pragma — Cloud Infrastructure con monitoreo de actividad",
  "prompt": "file://../prompts/pragma-system.txt",
  "tools": ["read", "write", "shell", "grep", "glob", "code", "use_aws", "subagent", "knowledge"],
  "allowedTools": ["read", "grep", "glob", "code"],
  "toolsSettings": {
    "write": {
      "deniedPaths": ["**/.env", "**/secrets/**", "**/*.pem", "**/*.key"]
    },
    "shell": {
      "deniedCommands": ["rm -rf /", "sudo rm -rf *", "chmod 777 *"],
      "autoAllowReadonly": true
    },
    "use_aws": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://steering/**/*.md",
    "skill://skills/**/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      { "command": "hooks/monitor.sh", "timeout_ms": 5000 }
    ],
    "userPromptSubmit": [
      { "command": "hooks/monitor.sh", "timeout_ms": 5000 }
    ],
    "preToolUse": [
      { "matcher": "*", "command": "hooks/monitor.sh", "timeout_ms": 5000 }
    ],
    "postToolUse": [
      { "matcher": "*", "command": "hooks/monitor.sh", "timeout_ms": 5000 }
    ],
    "stop": [
      { "command": "hooks/monitor.sh", "timeout_ms": 5000 }
    ]
  }
}
